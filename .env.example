# Copy to .env and fill in the keys you have. Council features only call
# providers whose keys are present; missing providers are skipped gracefully.
#
# Anthropic (Claude): NOT an API key. Claude calls go through your Claude Code
# subscription via the Claude Agent SDK (@anthropic-ai/claude-agent-sdk) running
# in the Node sidecar, using your existing Claude Code OAuth session.
# Prereq: `claude` CLI installed and logged in — run `claude` once and /login
# if you haven't. The Agent SDK inherits that auth.

# --- Other frontier providers (all optional) ---

# Google Gemini — has a generous free tier on AI Studio; get a key at
# https://aistudio.google.com/app/apikey. Recommended as the 2nd council voice.
GOOGLE_API_KEY=

# DeepSeek — very cheap pay-per-call, good 3rd voice. Get a key at
# https://platform.deepseek.com/api_keys.
DEEPSEEK_API_KEY=

# OpenAI — paid per call; ChatGPT Plus does NOT include API access.
OPENAI_API_KEY=

# xAI Grok — paid per call.
XAI_API_KEY=

# Mistral — paid per call.
MISTRAL_API_KEY=

# --- Local model host (Ollama default) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_SMALL_MODEL=gemma4:e4b
