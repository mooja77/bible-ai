{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bible AI",
  "version": "0.1.0",
  "identifier": "com.jm.bibleai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bible AI",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "devCsp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../data/corpus.sqlite": "corpus.sqlite",
      "../sidecar/index.mjs": "sidecar/index.mjs",
      "../sidecar/council.mjs": "sidecar/council.mjs",
      "../sidecar/explain.mjs": "sidecar/explain.mjs",
      "../sidecar/providers": "sidecar/providers",
      "../sidecar/grounded": "sidecar/grounded",
      "../sidecar/package.json": "sidecar/package.json",
      "../sidecar/package-lock.json": "sidecar/package-lock.json",
      "../sidecar/node": "sidecar/node",
      "../sidecar/node_modules": "sidecar/node_modules"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
